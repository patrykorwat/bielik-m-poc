# Konfiguracja Bielik-M PoC

# Provider LLM (claude lub mlx)
VITE_LLM_PROVIDER=claude

# Konfiguracja Claude (wymagane gdy VITE_LLM_PROVIDER=claude)
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Konfiguracja MLX (wymagane gdy VITE_LLM_PROVIDER=mlx)
VITE_MLX_BASE_URL=http://localhost:8080
VITE_MLX_MODEL=mlx-community/Llama-3.2-3B-Instruct-4bit

# Opcjonalne parametry MLX
VITE_MLX_TEMPERATURE=0.7
VITE_MLX_MAX_TOKENS=4096

# Remote API (OpenAI-compatible, e.g. Cyfronet LLM Lab)
VITE_REMOTE_API_URL=https://xxx
VITE_REMOTE_MODEL=speakleash/Bielik-11B-v3.0-Instruct

# Proxy URLs (defaults shown — override if running on different ports)
# VITE_MCP_PROXY_URL=http://localhost:3001
# VITE_LEAN_PROXY_URL=http://localhost:3002

# CLI test script env vars (used by test-dataset.py and benchmark.py)
# BIELIK_API_URL=https://xxx
# BIELIK_API_KEY=plg-xxx

# Uwaga: Te zmienne środowiskowe są opcjonalne.
# Możesz również konfigurować providera bezpośrednio w interfejsie użytkownika.
