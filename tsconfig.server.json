{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "dist-server",
    "rootDir": "src",
    "declaration": false,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "lib": ["ES2020"]
  },
  "include": [
    "src/services/classifierTypes.ts",
    "src/services/classifierService.ts",
    "src/services/deterministicSolvers.ts",
    "src/services/mlxAgent.ts"
  ]
}
