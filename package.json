{
  "name": "formulo",
  "version": "1.0.0",
  "description": "Asystent matematyczny dla maturzystów - rozwiązywanie zadań maturalnych krok po kroku z użyciem AI",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "mcp-proxy": "node mcp-proxy-server.js",
    "lean-proxy": "node lean-proxy-server.js",
    "rag-service": "cd rag_service && source venv/bin/activate && python main.py",
    "start:proxies": "concurrently \"npm run mcp-proxy\" \"npm run lean-proxy\"",
    "start:all": "concurrently \"npm run dev\" \"npm run mcp-proxy\" \"npm run lean-proxy\" \"npm run rag-service\"",
    "build:server": "tsc --project tsconfig.server.json",
    "generate:seo": "node seo/generate.js && node seo/generate-solutions.js",
    "heroku-postbuild": "npm run build && npm run build:server && npm run generate:seo && cd mcp-sympy-server && npm install && npm run build",
    "start:heroku": "node heroku-start.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "cors": "^2.8.5",
    "discord.js": "^14.16.3",
    "express": "^4.18.2",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "katex": "^0.16.28",
    "openai": "^4.0.0",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-katex": "^3.1.0",
    "react-syntax-highlighter": "^16.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.9.3",
    "vite": "^5.0.8"
  }
}
